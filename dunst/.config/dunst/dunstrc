[global]
    # General configuration
    font = "Inter 10"  # Set font to Inter, size 10
    background = "#1e1e1e"  # OLED dark background (very dark grey)
    foreground = "#ffffff"  # White text
    opacity = 0.85  # Transparency level (85%)
    timeout = 5  # Timeout in seconds before the notification disappears
    geometry = "x10+10-10"  # Position notifications at top-right with space for Qtile bar
    maxwidth = 300  # Max width of notifications (adjust as needed)

    # Allow clicking on notifications to dismiss them
    click_to_close = yes

    # Keep notifications on top of other windows
    stack_max = 3  # Show maximum 3 notifications stacked

    # Do not show notifications for the following event types
    notification_history = 1  # Limit number of historical notifications

[urgency_low]
    background = "#4e9a06"  # Green for low urgency
    foreground = "#ffffff"  # White text

[urgency_normal]
    background = "#edd400"  # Yellow for normal urgency
    foreground = "#000000"  # Black text

[urgency_critical]
    background = "#cc0000"  # Red for critical urgency
    foreground = "#ffffff"  # White text

[progress_bar]
    background = "#555555"  # Dark background for progress bar
    foreground = "#eeeeee"  # Light color for progress bar

[theme]
    # Optional themes you can tweak further
    border_width = 2
    border_color = "#ffffff"  # White border around notifications
    corner_radius = 5  # Rounded corners for the notifications
    padding = 10  # Padding inside the notification box
    vertical_gap = 5  # Space between stacked notifications
    horizontal_gap = 10  # Space between the notification and screen edge

