[global]
font = InterVariable Medium 11
format = "<b>%s</b>\n%b"

sort = yes
alignment = left
show_age_threshold = 60
word_wrap = yes
ignore_newline = no
hide_duplicate_count = true
sticky_history = yes
history_length = 20

title = "Dunst"
class = "Dunst"

corner_radius = 12
padding = 16
horizontal_padding = 24
frame_width = 2
frame_color = "#1a1a1a"
separator_height = 2
separator_color = frame
follow = mouse

transparency = 10
origin = top-right
offset = (10,35)
indicate_hidden = yes
shrink = no

icon_position = left
min_icon_size = 32
max_icon_size = 64
icon_theme = BeautySolar

mouse_left_click = close_current
mouse_right_click = close_all
mouse_middle_click = do_action

idle_threshold = 120

[urgency_low]
background = "#000000"
foreground = "#888888"
timeout = 8

[urgency_normal]
background = "#000000"
foreground = "#dddddd"
timeout = 10

[urgency_critical]
background = "#000000"
foreground = "#ff5555"
frame_color = "#ff5555"
timeout = 12
